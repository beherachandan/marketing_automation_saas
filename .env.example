# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — for /audit and /draft agents
ANTHROPIC_API_KEY=

# Slack app (create at https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_STATE_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption key for credential vault (generate: openssl rand -base64 32)
CREDENTIAL_ENCRYPTION_KEY=

# Vercel Cron bearer token (generate: openssl rand -base64 32)
# Leave empty locally — cron routes will accept unauthenticated requests for dev
CRON_SECRET=
