{
  "display_information": {
    "name": "Conduct",
    "description": "AEO content engine — audit and draft articles from Slack.",
    "background_color": "#1d1c1d",
    "long_description": "Conduct runs your AEO content pipeline inside Slack. Use /audit to score a page against your rubric, /draft to generate a new article from a topic brief, or mention the bot in a thread to iterate. All runs use your workspace's brand voice, ICPs, and rubric captured during onboarding."
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "conduct",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/audit",
        "url": "https://YOUR_DOMAIN/api/slack/commands",
        "description": "Score a URL against your AEO rubric",
        "usage_hint": "https://your-site.com/page",
        "should_escape": false
      },
      {
        "command": "/draft",
        "url": "https://YOUR_DOMAIN/api/slack/commands",
        "description": "Draft an article from a topic brief",
        "usage_hint": "topic or keyword phrase",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [
      "https://YOUR_DOMAIN/api/slack/oauth_redirect"
    ],
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "chat:write.public",
        "commands",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "links:read",
        "links:write",
        "mpim:history",
        "mpim:read",
        "reactions:read",
        "reactions:write",
        "users:read",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://YOUR_DOMAIN/api/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://YOUR_DOMAIN/api/slack/interactivity"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
